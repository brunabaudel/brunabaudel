default_platform(:ios)

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  private_lane :api_key do
    app_store_connect_api_key(
      key_id: ENV["APPSTORE_API_KEY_ID"],
      issuer_id: ENV["APPSTORE_ISSUER_ID"],
      key_filepath: ENV.fetch("APPSTORE_API_KEY_PATH"),
      duration: 1200,
      in_house: false
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    key = api_key
    team_id = ENV.fetch("DEVELOPMENT_TEAM")

    produce(
      api_key: key,
      app_identifier: "com.brunabaudel.BasicApp",
      app_name: "BasicApp",
      team_id: team_id,
      skip_itc: false,
      skip_devcenter: false
    )

    increment_build_number(
      xcodeproj: "BasicApp.xcodeproj",
      build_number: ENV.fetch("BUILD_NUMBER", "1")
    )

    cert(
      api_key: key,
      team_id: team_id,
      development: false
    )

    sigh(
      api_key: key,
      team_id: team_id,
      app_identifier: "com.brunabaudel.BasicApp"
    )

    build_app(
      project: "BasicApp.xcodeproj",
      scheme: "BasicApp",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "BasicApp.ipa"
    )

    upload_to_testflight(
      api_key: key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
