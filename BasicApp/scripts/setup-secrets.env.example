# Copy to setup-secrets.env and fill in your values, then run:
#   ./scripts/configure-github-secrets.sh
#
# Do NOT commit setup-secrets.env — it contains your API private key.

# 10-character Team ID from https://developer.apple.com/account#MembershipDetailsCard
DEVELOPMENT_TEAM=XXXXXXXXXX

# From App Store Connect → Users and Access → Integrations → App Store Connect API
APPSTORE_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
APPSTORE_API_KEY_ID=XXXXXXXXXX

# Paste the full contents of your AuthKey_XXXXXX.p8 file (including BEGIN/END lines)
APPSTORE_API_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"
